# Google Calendar Integration
# To get these credentials:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project
# 3. Enable the Google Calendar API
# 4. Create a service account and download the JSON key
# 5. Copy the entire JSON object into GOOGLE_SERVICE_ACCOUNT_KEY
# 6. Share your Google Calendar with the service account email
# 7. Get your calendar ID from Google Calendar settings
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_CALENDAR_ID=

# Sanity CMS
# Get these from your Sanity project dashboard (manage.sanity.io)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-06
SANITY_API_TOKEN=

# WordPress (optional - for backwards compatibility)
NEXT_PUBLIC_WORDPRESS_URL=
